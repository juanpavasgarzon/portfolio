---
import { useT, type Lang } from '@/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useT(lang);
---

<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a href="#top" class="brand" aria-label="Inicio">
      <span class="brand-logo" aria-hidden="true">
        <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 12 L4 20 L8 28"  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <path d="M32 12 L36 20 L32 28" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          <text x="20" y="25.5" text-anchor="middle" font-family="Syne, sans-serif" font-weight="800" font-size="13" fill="currentColor" letter-spacing="-0.5">jp</text>
        </svg>
      </span>
      <span>pavas<span style="color:var(--accent)">.</span>dev</span>
    </a>

    <nav class="nav-links" id="navLinks">
      <a href="#skills">{t('nav.skills')}</a>
      <a href="#experience">{t('nav.experience')}</a>
      <a href="#work">{t('nav.work')}</a>
      <a href="#blog">{t('nav.blog')}</a>
      <a href="#contact">{t('nav.contact')}</a>
    </nav>

    <div class="nav-tools">
      <div class="lang-select-wrap" aria-label="Language">
        <span class="lang-flag" aria-hidden="true">{lang === 'es' ? '🇨🇴' : '🇺🇸'}</span>
        <span class="lang-label">{lang === 'es' ? 'Español' : 'English'}</span>
        <svg class="lang-chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
        <select class="lang-select" id="langSelect" aria-label="Cambiar idioma / Change language">
          <option value="es" selected={lang === 'es'}>🇨🇴 Español</option>
          <option value="en" selected={lang === 'en'}>🇺🇸 English</option>
        </select>
      </div>

      <button class="tool-btn theme-toggle" id="themeToggle" aria-label="Toggle theme">
        <svg class="sun-icon"  viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
        <svg class="moon-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>

      <button class="burger" id="burger" aria-label="Menu"><span></span></button>
    </div>
  </div>
</header>
